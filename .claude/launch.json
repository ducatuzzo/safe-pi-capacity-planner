{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "safe-pi-capacity-planner", "run", "dev:client"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "Backend (Express + Socket.io)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "safe-pi-capacity-planner", "run", "dev:server"],
      "port": 3001
    },
    {
      "name": "Full Stack (Frontend + Backend)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "safe-pi-capacity-planner", "run", "dev"],
      "port": 5173,
      "autoPort": true
    }
  ]
}
