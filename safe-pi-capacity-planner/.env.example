# SAFe PI Capacity Planner – Umgebungsvariablen
# Kopiere diese Datei zu `.env` und passe die Werte an.
# `.env` wird NICHT committet (siehe .gitignore).

# -------------------------------------------------------
# VITE_BACKEND_URL
# Lokal:       leer lassen → Vite-Proxy leitet /api + /socket.io an localhost:3001 weiter
# Produktion:  Railway-URL eintragen (in Vercel → Settings → Environment Variables setzen)
# Beispiel:    VITE_BACKEND_URL=https://safe-pi-capacity-planner-production.up.railway.app
# -------------------------------------------------------
VITE_BACKEND_URL=

# -------------------------------------------------------
# DEFAULT_ADMIN_CODE  (nur Backend / Railway)
# Initialer Admin-Code beim ersten Start des Backends.
# Lokal nicht nötig — Fallback-Wert greift automatisch.
# In Railway unter Environment Variables setzen, nicht hier.
# -------------------------------------------------------
# DEFAULT_ADMIN_CODE=00000815
